# -*- coding: utf-8 -*-

import datetime
from fastapi import FastAPI, Header, HTTPException
from fastapi.responses import HTMLResponse
from pydantic import BaseModel
import uvicorn

app = FastAPI()

API_TOKEN = "epf2026_secret"
database = []

class NewsEntry(BaseModel):
    agent_name: str
    topic: str
    title: str
    summary: str
    url: str
    confidence: float = 0.0

@app.post("/publish")
def publish_news(entry: NewsEntry, x_token: str = Header(None)):

    if x_token != API_TOKEN:
        raise HTTPException(status_code=403, detail="Token inválido")

    database.append(entry.dict())

    return {"ok": True, "total": len(database)}

@app.get("/", response_class=HTMLResponse)
def home():

    html = "<h1>EPF News Hub</h1>"

    for n in reversed(database):
        html += f"<h3>{n['title']}</h3><p>{n['summary']}</p><hr>"

    return html


if __name__ == "__main__":
    uvicorn.run(app, host="0.0.0.0", port=8080)
